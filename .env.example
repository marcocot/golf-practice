# Database
POSTGRES_USER=golf
POSTGRES_PASSWORD=golf
POSTGRES_DB=golf
POSTGRES_PORT=5432
DATABASE_URL=postgresql://golf:golf@localhost:5432/golf?schema=public

# API
API_PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Auth (BetterAuth)
BETTER_AUTH_SECRET=dev-better-auth-secret-change-me
BETTER_AUTH_URL=http://localhost:3000

# Mail (Mailpit in dev)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM="Golf Practice <no-reply@golf.local>"
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# Web origin used for links in emails (verification, reset)
WEB_ORIGIN=http://localhost:5173
