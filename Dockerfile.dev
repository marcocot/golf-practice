# Shared dev image for api and web. Source is bind-mounted at runtime;
# node_modules live in named/anonymous volumes so the container keeps its own
# Linux-native binaries instead of the host's.
FROM node:22-alpine
RUN corepack enable
WORKDIR /repo
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json tsconfig.base.json ./
COPY apps/api/package.json ./apps/api/
COPY apps/web/package.json ./apps/web/
COPY apps/api/prisma ./apps/api/prisma
RUN pnpm install --frozen-lockfile
